# ---------------------------------------------------------------------------
# PRODUCTION environment example. Copy to `.env` on the server and fill in
# strong, unique secrets. NEVER commit the real file. Generate secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# ---------------------------------------------------------------------------

APP_ENV=production
APP_SECRET_KEY=__CHANGE_ME__
FRONTEND_URL=https://your-domain.example
BACKEND_URL=https://your-domain.example

# --- Database (managed or the compose Postgres) ---
POSTGRES_PASSWORD=__CHANGE_ME_STRONG__
DATABASE_URL=postgresql+asyncpg://xba:__CHANGE_ME_STRONG__@postgres:5432/xba

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- X API (set to use real data; leave X_PROVIDER=mock for a demo deploy) ---
X_PROVIDER=x_api
X_API_BEARER_TOKEN=__YOUR_X_API_BEARER_TOKEN__
X_DEFAULT_POST_LIMIT=200
X_MAX_POST_LIMIT=500
X_CACHE_TTL_SECONDS=3600

# --- Auth ---
JWT_SECRET_KEY=__CHANGE_ME__
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Reports ---
REPORT_STORAGE_PATH=/app/reports_storage

# --- Analysis ---
LOW_CONFIDENCE_POST_THRESHOLD=10
DEFAULT_TIMEZONE=UTC

# --- Observability ---
LOG_LEVEL=INFO
SENTRY_DSN=

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=30
ANALYSIS_RATE_LIMIT_PER_HOUR=20
