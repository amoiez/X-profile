# ---------------------------------------------------------------------------
# X Behavior Analyzer — example environment configuration
# Copy to `.env` and adjust. The default configuration runs in DEMO MODE
# using the mock provider and requires NO X API credentials.
# NEVER commit a real .env file. Secrets belong only in the environment.
# ---------------------------------------------------------------------------

# --- Application ---
APP_ENV=development                 # development | production | test
APP_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# --- Database ---
# Production uses PostgreSQL. For quick local dev you may use SQLite:
#   DATABASE_URL=sqlite+aiosqlite:///./dev.db
DATABASE_URL=postgresql+asyncpg://xba:xba_password@postgres:5432/xba

# --- Redis (queue / cache / job progress / rate limiting) ---
REDIS_URL=redis://redis:6379/0

# --- X (Twitter) API provider ---
# X_PROVIDER selects the data source: `mock` (default, no credentials needed)
# or `x_api` (real production data, requires a bearer token).
X_PROVIDER=mock
X_API_BEARER_TOKEN=
X_API_BASE_URL=https://api.twitter.com/2
X_DEFAULT_POST_LIMIT=200
X_MAX_POST_LIMIT=500
X_CACHE_TTL_SECONDS=3600
X_REQUEST_TIMEOUT_SECONDS=15
X_MAX_RETRIES=3
ALLOW_ARBITRARY_MOCK_PROFILES=false

# --- Authentication (JWT) ---
JWT_SECRET_KEY=change-me-another-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Reports ---
REPORT_STORAGE_PATH=/app/reports_storage

# --- Analysis defaults ---
LOW_CONFIDENCE_POST_THRESHOLD=10    # below this many posts => "Low confidence"
DEFAULT_TIMEZONE=UTC

# --- Observability ---
LOG_LEVEL=INFO
SENTRY_DSN=

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=30
ANALYSIS_RATE_LIMIT_PER_HOUR=20
